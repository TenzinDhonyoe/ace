{
  "name": "ace-study-template",
  "version": "0.3.0",
  "description": "Pure renderSite(config) function + CLI that turn a site.config.json into a self-contained HTML study site. Runtime-agnostic: Node, Bun, Deno, Workers, browsers.",
  "license": "MIT",
  "type": "module",
  "main": "./src/render.js",
  "bin": {
    "ace-template": "./bin/cli.js"
  },
  "exports": {
    ".": "./src/render.js",
    "./cli": "./bin/cli.js"
  },
  "files": ["src/", "bin/", "README.md"],
  "scripts": {
    "test": "bun test",
    "prepublishOnly": "bun test"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "ace-study-components": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TenzinDhonyoe/ace.git",
    "directory": "packages/ace-template"
  },
  "homepage": "https://github.com/TenzinDhonyoe/ace#readme",
  "bugs": "https://github.com/TenzinDhonyoe/ace/issues",
  "keywords": ["education", "study", "ai-generated", "interactive", "exam-prep", "static-site", "html-generator"]
}
